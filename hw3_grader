#!/bin/bash
DIR="$(cd "$(dirname "\$0")" && pwd)"
ARCH="$(uname -m)"
if [ "$ARCH" = "x86_64" ]; then
    exec "$DIR/hw3_grader_x86_64" "$@"
elif [ "$ARCH" = "aarch64" ]; then
    exec "$DIR/hw3_grader_aarch64" "$@"
else
    echo "Unsupported architecture: $ARCH"
    echo "This grader supports x86_64 and aarch64 only."
    exit 1
fi
